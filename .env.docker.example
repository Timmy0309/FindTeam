# Скопируйте в .env в корне проекта перед docker-compose up:
#   cp .env.docker.example .env

PORT=5000
# Минимум 32 символа, уникальное значение для production
JWT_SECRET=replace_with_random_secret_at_least_32_chars_long

DB_HOST=localhost
DB_PORT=5432
DB_NAME=gameteam_db
DB_USER=postgres
DB_PASSWORD=postgres

# Разрешённые origins через запятую
CORS_ORIGIN=http://localhost:3000

# Учётная запись администратора (создаётся при первом запуске)
ADMIN_EMAIL=admin@findteam.local
ADMIN_PASSWORD=AdminFindTeam2024!Secure
